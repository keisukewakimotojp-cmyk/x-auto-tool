# ================================
# Claude API
# ================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ================================
# X (Twitter) API v2
# ================================
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here
X_BEARER_TOKEN=your_x_bearer_token_here

# ================================
# Trend source settings
# ================================
# "rss" | "google_trends" | "custom"
TREND_SOURCE=rss
TREND_RSS_URL=https://news.google.com/rss?hl=ja&gl=JP&ceid=JP:ja

# ================================
# Tweet generation settings
# ================================
TWEET_LANGUAGE=ja
TWEET_TONE=friendly
# e.g. "tech", "news", "entertainment"
TWEET_TOPIC=

# ================================
# Future: multi-account
# ================================
# ACTIVE_ACCOUNT=account_a
# ACCOUNT_A_ACCESS_TOKEN=...
# ACCOUNT_B_ACCESS_TOKEN=...

# ================================
# Future: scheduling
# ================================
# POST_SCHEDULE=0 9,18 * * *
